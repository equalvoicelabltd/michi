@tailwind base;
@tailwind components;
@tailwind utilities;

/* Michi 品牌自定義樣式 */

@layer base {
  :root {
    --michi-primary: #003366;
    --michi-secondary: #FF69B4;
    --michi-accent: #FFD700;
    --michi-light: #F8F9FA;
    --michi-dark: #666666;
    --michi-border: #E8E8E8;
  }

  body {
    @apply bg-michi-light text-gray-900;
  }
}

@layer components {
  /* Michi 按鈕樣式 */
  .btn-michi {
    @apply bg-michi-secondary text-white px-6 py-3 rounded-lg
           font-semibold transition-all duration-300
           hover:opacity-90 hover:shadow-lg
           active:scale-95;
  }

  .btn-michi-outline {
    @apply border-2 border-michi-secondary text-michi-secondary
           px-6 py-3 rounded-lg font-semibold
           transition-all duration-300
           hover:bg-michi-secondary hover:text-white;
  }

  .btn-michi-primary {
    @apply bg-michi-primary text-white px-6 py-3 rounded-lg
           font-semibold transition-all duration-300
           hover:opacity-90 hover:shadow-lg;
  }

  /* Michi 卡片樣式 */
  .card-michi {
    @apply bg-white p-6 rounded-xl shadow-md
           border border-michi-border
           transition-all duration-300
           hover:shadow-xl hover:-translate-y-1;
  }

  .card-michi-featured {
    @apply bg-gradient-to-br from-michi-primary to-michi-secondary
           text-white p-6 rounded-xl shadow-lg
           transition-all duration-300
           hover:shadow-2xl hover:-translate-y-1;
  }

  /* Michi 徽章樣式 */
  .badge-michi {
    @apply inline-flex items-center px-3 py-1
           rounded-full text-xs font-semibold
           bg-michi-accent text-michi-primary;
  }

  .badge-michi-verified {
    @apply inline-flex items-center px-3 py-1
           rounded-full text-xs font-semibold
           bg-michi-primary text-white;
  }

  .badge-michi-new {
    @apply inline-flex items-center px-3 py-1
           rounded-full text-xs font-semibold
           bg-michi-secondary text-white;
  }

  /* Michi 輸入框樣式 */
  .input-michi {
    @apply w-full px-4 py-2 rounded-lg
           border border-michi-border
           focus:outline-none focus:ring-2
           focus:ring-michi-secondary
           transition-all duration-300;
  }

  /* Michi 標題樣式 */
  .heading-michi {
    @apply text-michi-primary font-bold;
  }

  .heading-michi-gradient {
    @apply bg-gradient-to-r from-michi-primary to-michi-secondary
           bg-clip-text text-transparent font-bold;
  }

  /* Michi 分隔線 */
  .divider-michi {
    @apply border-t border-michi-border my-8;
  }

  /* Michi 容器 */
  .container-michi {
    @apply max-w-7xl mx-auto px-4 sm:px-6 lg:px-8;
  }

  /* Michi 導航鏈接 */
  .nav-link-michi {
    @apply text-gray-700 hover:text-michi-primary
           transition-colors duration-300
           font-medium;
  }

  .nav-link-michi-active {
    @apply text-michi-primary font-semibold
           border-b-2 border-michi-secondary;
  }

  /* Michi 評分星星 */
  .rating-star-michi {
    @apply text-michi-accent;
  }

  /* Michi 加載動畫 */
  .loading-michi {
    @apply animate-pulse bg-gray-200 rounded;
  }

  /* Michi 標籤 */
  .tag-michi {
    @apply inline-block px-3 py-1
           bg-michi-light text-michi-dark
           rounded-full text-sm
           border border-michi-border
           hover:bg-michi-primary hover:text-white
           transition-all duration-300
           cursor-pointer;
  }
}

@layer utilities {
  /* 文字漸變 */
  .text-gradient-michi {
    @apply bg-gradient-to-r from-michi-primary to-michi-secondary
           bg-clip-text text-transparent;
  }

  /* 背景漸變 */
  .bg-gradient-michi {
    @apply bg-gradient-to-br from-michi-primary to-michi-secondary;
  }

  /* 陰影效果 */
  .shadow-michi {
    box-shadow: 0 4px 20px rgba(0, 51, 102, 0.1);
  }

  .shadow-michi-lg {
    box-shadow: 0 8px 30px rgba(0, 51, 102, 0.15);
  }

  /* 平滑滾動 */
  .scroll-smooth-michi {
    scroll-behavior: smooth;
  }
}

/* 響應式字體大小 */
@media (max-width: 640px) {
  html {
    font-size: 14px;
  }
}

/* 暗色模式支持（未來擴展） */
@media (prefers-color-scheme: dark) {
  /* 可以在這裡添加暗色模式樣式 */
}

/* 自定義滾動條 */
::-webkit-scrollbar {
  width: 8px;
  height: 8px;
}

::-webkit-scrollbar-track {
  @apply bg-gray-100;
}

::-webkit-scrollbar-thumb {
  @apply bg-michi-primary rounded-full;
}

::-webkit-scrollbar-thumb:hover {
  @apply bg-michi-secondary;
}

/* 選中文字樣式 */
::selection {
  @apply bg-michi-secondary text-white;
}

/* Focus 可見性改進 */
*:focus-visible {
  @apply outline-2 outline-offset-2 outline-michi-secondary;
}